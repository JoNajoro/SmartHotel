{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "complexity": ["error", 5],
    "max-depth": ["error", 4],
    "max-lines": ["warn", 300],
    "max-lines-per-function": ["warn", 50],
    "max-nested-callbacks": ["error", 3],
    "max-params": ["warn", 5],
    "no-console": "off",
    "no-unused-vars": ["error", { "args": "none" }],
    "prefer-const": "error",
    "no-var": "error",
    "semi": ["error", "always"],
    "quotes": ["error", "double"]
  }
}
